<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!--
      IIS configuration for RPL Analytics hosted under /rpl subfolder.

      Prerequisites on the IIS server:
        1. URL Rewrite module  (iis.net/downloads/microsoft/url-rewrite)
        2. Application Request Routing (ARR) module (iis.net/downloads/microsoft/application-request-routing)
           — needed only for the API proxy rule below.

      The Node.js server must be running separately:
        set BASE_PATH=/rpl
        set PORT=3000
        node server.cjs

      IIS application path: point the /rpl virtual directory to the dist\ folder.
    -->

    <rewrite>
      <rules>

        <!-- 1. Proxy all /rpl/api/* calls to the Node.js server (requires ARR) -->
        <rule name="API Proxy" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://localhost:3000/rpl/api/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_ORIGINAL_URL" value="{UNENCODED_URL}" />
          </serverVariables>
        </rule>

        <!-- 2. SPA fallback — serve index.html for any route not matching a real file -->
        <rule name="SPA Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile"      negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.html" />
        </rule>

      </rules>
    </rewrite>

    <!-- Allow JS modules and font files to be served correctly -->
    <staticContent>
      <remove fileExtension=".js"   />
      <mimeMap fileExtension=".js"   mimeType="application/javascript" />
      <remove fileExtension=".mjs"  />
      <mimeMap fileExtension=".mjs"  mimeType="application/javascript" />
      <remove fileExtension=".woff2"/>
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
    </staticContent>

    <!-- Prevent IIS from returning 404 for SPA deep-links -->
    <httpErrors existingResponse="PassThrough" />

  </system.webServer>
</configuration>
